#!/usr/bin/env python3
"""
session-logger hook

Appends a structured JSON Lines entry to a session log file each time it is
called.  Intended to be invoked at session start and session end by an agent
orchestrator to maintain a persistent, append-only record of agent activity.

Usage:
    python hooks/session-logger --event start --agent my-agent
    python hooks/session-logger --event end   --agent my-agent [--outcome success|failure]

The log is written to: session-logs/sessions.jsonl  (gitignored by default)

Exit codes:
    0 - log entry written successfully
    1 - error writing log entry
"""

import argparse
import json
import os
import sys
import time
from datetime import datetime, timezone
from pathlib import Path


def get_git_context() -> dict:
    """Collect lightweight git metadata for the log entry."""
    import subprocess

    ctx: dict = {}
    for key, cmd in [
        ("branch", ["git", "rev-parse", "--abbrev-ref", "HEAD"]),
        ("commit", ["git", "rev-parse", "--short", "HEAD"]),
    ]:
        result = subprocess.run(cmd, capture_output=True, text=True, check=False)
        if result.returncode == 0:
            ctx[key] = result.stdout.strip()
    return ctx


def main() -> int:
    parser = argparse.ArgumentParser(description="Agent session logger hook")
    parser.add_argument(
        "--event",
        required=True,
        choices=["start", "end", "tool_call", "error"],
        help="Type of session event to log",
    )
    parser.add_argument("--agent", required=True, help="Agent identifier / name")
    parser.add_argument(
        "--outcome",
        choices=["success", "failure", "unknown"],
        default="unknown",
        help="Outcome for 'end' events",
    )
    parser.add_argument("--message", default="", help="Optional free-text message")
    parser.add_argument(
        "--log-dir",
        default="session-logs",
        help="Directory for session log files (default: session-logs/)",
    )
    args = parser.parse_args()

    log_dir = Path(args.log_dir)
    try:
        log_dir.mkdir(parents=True, exist_ok=True)
    except OSError as exc:
        print(f"[session-logger] Cannot create log directory: {exc}", file=sys.stderr)
        return 1

    log_file = log_dir / "sessions.jsonl"

    entry = {
        "timestamp": time.time(),
        "iso_time": datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
        "event": args.event,
        "agent": args.agent,
        "outcome": args.outcome if args.event == "end" else None,
        "message": args.message,
        "pid": os.getpid(),
        "git": get_git_context(),
    }
    # Remove None values to keep the log compact.
    entry = {k: v for k, v in entry.items() if v is not None}

    try:
        with log_file.open("a", encoding="utf-8") as f:
            f.write(json.dumps(entry) + "\n")
    except OSError as exc:
        print(f"[session-logger] Failed to write log: {exc}", file=sys.stderr)
        return 1

    print(
        f"[session-logger] {entry['iso_time']} event={args.event} agent={args.agent}",
        file=sys.stderr,
    )
    return 0


if __name__ == "__main__":
    sys.exit(main())
