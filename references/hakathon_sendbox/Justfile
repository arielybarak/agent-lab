# CrashTech 2026 Hackathon — task runner
# Run `just` to list available recipes.

# Use PowerShell on Windows; keep the default sh on Unix.
set windows-shell := ["powershell.exe", "-NoLogo", "-Command"]

default:
    @just --list

# --- FPGA (DE10-Lite / Quartus) ---
# Compile a project. Usage: just fpga-build challenges/<name>/fpga <project>
fpga-build dir project:
    cd {{dir}} && quartus_sh --flow compile {{project}}

# Program the board (run from Windows PowerShell — Quartus can't use WSL paths).
# Usage: just fpga-prog challenges/<name>/fpga <project>
fpga-prog dir project:
    cd {{dir}} && quartus_pgm -c "USB-Blaster [USB-0]" -m JTAG -o "P;output_files/{{project}}.sof"

# Run a reusable brick's ModelSim testbench. Usage: just sim uart_loopback
sim module:
    cd projects/common/fpga/sim && vsim -c -do {{module}}_tb.do

# --- ESP32 (PlatformIO, from WSL after `usbipd attach --wsl`) ---
# Usage: just esp32-build challenges/<name>/esp32
esp32-build dir:
    cd {{dir}} && pio run

# Upload. Usage: just esp32-flash challenges/<name>/esp32 [port]
esp32-flash dir port="/dev/ttyUSB0":
    cd {{dir}} && pio run -t upload --upload-port {{port}}

# Serial monitor. Usage: just esp32-monitor [port] [baud]
esp32-monitor port="/dev/ttyUSB0" baud="115200":
    pio device monitor --port {{port}} --baud {{baud}}

# Scaffold a new challenge from the compiling template.
# Usage: just new-challenge <name>
new-challenge name:
    mkdir -p challenges/{{name}}
    cp -r challenges/_template/fpga  challenges/{{name}}/fpga
    cp -r challenges/_template/esp32 challenges/{{name}}/esp32
    @echo "Created challenges/{{name}}/{fpga,esp32} — rename project files, then edit."

# --- Python tooling (helper scripts only) ---
py-fmt:
    uv run ruff format .

py-lint:
    uv run ruff check .

# --- MCP ---
# Diagnose MCP setup: runtimes, env vars, follow-ups.
mcp:
    python scripts/mcp_check.py

# --- Agent helpers (print paths to load; no model tokens) ---
# List every project skill.
skills:
    @echo "Project skills (load via: read .claude/skills/<name>/SKILL.md):"
    @ls -1 .claude/skills | sed 's/^/  /'

# Show frontmatter of each skill (what gets auto-suggested to the agent).
skills-list:
    @find .claude/skills -name SKILL.md -print -exec head -3 {} \; -exec echo "" \;

# Print the hardware instruction file to load before RTL/wiring.
hw:
    @echo "Load: .claude/instructions/hardware/README.md"
